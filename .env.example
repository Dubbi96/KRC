# ─── Katab Runner Console (KRC) Configuration ───

# Cloud Dashboard (KCD) connection
CLOUD_API_URL=http://katab-prod-kcd-alb-1334992113.ap-northeast-2.elb.amazonaws.com/api/v1
RUNNER_API_TOKEN=ktr_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Control Plane (KCP) connection
CONTROL_PLANE_URL=http://katab-prod-kcp-alb-2032050242.ap-northeast-2.elb.amazonaws.com/api
NODE_API_TOKEN=ktn_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Runner identity
NODE_NAME=my-mac
RUNNER_PLATFORMS=web
# RUNNER_PLATFORMS=web,ios          # iOS 테스트 포함
# RUNNER_PLATFORMS=web,ios,android  # 모든 플랫폼

# Local API
LOCAL_API_PORT=5001
LOCAL_API_BIND=0.0.0.0

# Optional: custom paths (defaults work in most cases)
# SCENARIO_DIR=./scenarios
# REPORT_DIR=./reports
# KATAB_CLI_PATH=./packages/recorder/dist/cli.js
