#!/bin/bash
# krc — Katab Runner Console CLI
set -euo pipefail

KRC_HOME="${KRC_HOME:-$HOME/Katab/KRC}"
KRC_LOG_DIR="$KRC_HOME/logs"
KRC_PID_FILE="$KRC_LOG_DIR/krc.pid"
KRC_LOG_FILE="$KRC_LOG_DIR/krc.log"
KRC_UPDATE_LOG="$KRC_LOG_DIR/auto-update.log"
LAUNCHD_LABEL="com.katab.krc"
LAUNCHD_UPDATER_LABEL="com.katab.krc-updater"
PLIST_DIR="$HOME/Library/LaunchAgents"

mkdir -p "$KRC_LOG_DIR"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

print_banner() {
  echo -e "${CYAN}"
  echo "  ╔═══════════════════════════════════╗"
  echo "  ║   Katab Runner Console (KRC)      ║"
  echo "  ╚═══════════════════════════════════╝"
  echo -e "${NC}"
}

get_version() {
  cd "$KRC_HOME"
  local commit=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
  local date=$(git log -1 --format="%ci" 2>/dev/null | cut -d' ' -f1 || echo "unknown")
  echo "$commit ($date)"
}

is_running() {
  if launchctl list "$LAUNCHD_LABEL" &>/dev/null; then
    local pid=$(launchctl list "$LAUNCHD_LABEL" 2>/dev/null | grep PID | awk '{print $NF}')
    if [ -n "$pid" ] && [ "$pid" != "-" ] && kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi
  # Fallback: check PID file
  if [ -f "$KRC_PID_FILE" ]; then
    local pid=$(cat "$KRC_PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi
  return 1
}

get_pid() {
  if [ -f "$KRC_PID_FILE" ]; then
    local pid=$(cat "$KRC_PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
      echo "$pid"
      return
    fi
  fi
  # Try launchd
  launchctl list "$LAUNCHD_LABEL" 2>/dev/null | grep -oE '[0-9]+' | head -1
}

cmd_start() {
  if is_running; then
    echo -e "${YELLOW}KRC is already running (PID: $(get_pid))${NC}"
    return 0
  fi

  # Also check via pgrep — process may be alive but launchd/PID check missed it
  if pgrep -f "node.*dist/main.js" &>/dev/null; then
    local pid=$(pgrep -f "node.*dist/main.js" | head -1)
    echo -e "${YELLOW}KRC is already running (PID: $pid)${NC}"
    return 0
  fi

  # Kill leftover orphans only when we know nothing should be running
  kill_orphans

  echo -e "${CYAN}Starting KRC...${NC}"

  # Check if launchd plist exists
  if [ -f "$PLIST_DIR/$LAUNCHD_LABEL.plist" ]; then
    launchctl load "$PLIST_DIR/$LAUNCHD_LABEL.plist" 2>/dev/null || true
    launchctl start "$LAUNCHD_LABEL" 2>/dev/null || true
  else
    # Direct start without launchd
    cd "$KRC_HOME"
    if [ ! -d "dist" ]; then
      echo -e "${YELLOW}Building KRC first...${NC}"
      npm run build
      (cd packages/recorder && npm run build)
    fi
    nohup node dist/main.js >> "$KRC_LOG_FILE" 2>&1 &
    echo $! > "$KRC_PID_FILE"
  fi

  # Wait up to 10s for startup (Intel Mac Mini can be slow)
  for i in {1..10}; do
    sleep 1
    if is_running || pgrep -f "node.*dist/main.js" &>/dev/null; then
      local pid=$(get_pid)
      [ -z "$pid" ] && pid=$(pgrep -f "node.*dist/main.js" | head -1)
      echo -e "${GREEN}KRC started (PID: $pid)${NC}"
      return 0
    fi
  done

  echo -e "${RED}Failed to start KRC. Check logs: krc logs${NC}"
  return 1
}

kill_orphans() {
  # Kill orphan ts-node-dev processes (dev mode leftovers)
  local tspids=$(pgrep -f "ts-node-dev.*src/main.ts" 2>/dev/null || true)
  if [ -n "$tspids" ]; then
    echo -e "  ${YELLOW}Cleaning up orphan ts-node-dev process(es)...${NC}"
    echo "$tspids" | xargs kill 2>/dev/null || true
    sleep 1
    echo "$tspids" | xargs kill -9 2>/dev/null || true
  fi

  # Kill ALL KRC node processes (only called when nothing should be running)
  local pids=$(pgrep -f "node.*dist/main.js" 2>/dev/null || true)
  if [ -n "$pids" ]; then
    local count=$(echo "$pids" | wc -l | xargs)
    echo -e "  ${YELLOW}Cleaning up $count leftover KRC process(es)...${NC}"
    echo "$pids" | xargs kill 2>/dev/null || true
    sleep 2
    echo "$pids" | xargs kill -9 2>/dev/null || true
  fi
}

cmd_stop() {
  echo -e "${CYAN}Stopping KRC...${NC}"

  # IMPORTANT: Unload launchd plist FIRST to prevent KeepAlive auto-restart
  if [ -f "$PLIST_DIR/$LAUNCHD_LABEL.plist" ]; then
    launchctl unload "$PLIST_DIR/$LAUNCHD_LABEL.plist" 2>/dev/null || true
  fi

  # Kill process directly
  local pid=$(get_pid)
  if [ -n "$pid" ]; then
    kill "$pid" 2>/dev/null || true
    for i in {1..5}; do
      kill -0 "$pid" 2>/dev/null || break
      sleep 1
    done
    kill -9 "$pid" 2>/dev/null || true
  fi

  # Kill any remaining orphan processes
  kill_orphans

  rm -f "$KRC_PID_FILE"
  echo -e "${GREEN}KRC stopped${NC}"
}

cmd_restart() {
  cmd_stop
  sleep 1
  cmd_start
}

cmd_update() {
  echo -e "${CYAN}Checking for updates...${NC}"
  cd "$KRC_HOME"

  git fetch origin main --quiet

  local LOCAL=$(git rev-parse HEAD)
  local REMOTE=$(git rev-parse origin/main)

  if [ "$LOCAL" = "$REMOTE" ]; then
    echo -e "${GREEN}Already up to date (${LOCAL:0:7})${NC}"
    return 0
  fi

  echo -e "${YELLOW}New version available: ${LOCAL:0:7} → ${REMOTE:0:7}${NC}"
  echo ""

  # Show changelog
  echo -e "${CYAN}Changes:${NC}"
  git log --oneline "$LOCAL..$REMOTE" | head -10
  echo ""

  # Pull and rebuild
  echo -e "${CYAN}Pulling updates...${NC}"
  git pull origin main --ff-only

  echo -e "${CYAN}Installing dependencies...${NC}"
  npm install

  echo -e "${CYAN}Building KRC...${NC}"
  npm run build

  echo -e "${CYAN}Building recorder...${NC}"
  (cd packages/recorder && npm install && npm run build)

  # Install Playwright browsers if needed
  npx playwright install chromium 2>/dev/null || true

  # Restart if running
  if is_running; then
    echo -e "${CYAN}Restarting KRC...${NC}"
    cmd_restart
  fi

  echo -e "${GREEN}Updated to $(get_version)${NC}"
}

cmd_status() {
  print_banner
  echo -e "  ${CYAN}Version:${NC}    $(get_version)"
  echo -e "  ${CYAN}Home:${NC}       $KRC_HOME"

  if is_running; then
    echo -e "  ${CYAN}Status:${NC}     ${GREEN}Running${NC} (PID: $(get_pid))"
  else
    echo -e "  ${CYAN}Status:${NC}     ${RED}Stopped${NC}"
  fi

  # .env info
  if [ -f "$KRC_HOME/.env" ]; then
    local cloud_url=$(grep CLOUD_API_URL "$KRC_HOME/.env" 2>/dev/null | cut -d= -f2-)
    local platforms=$(grep RUNNER_PLATFORMS "$KRC_HOME/.env" 2>/dev/null | cut -d= -f2-)
    local node_name=$(grep NODE_NAME "$KRC_HOME/.env" 2>/dev/null | cut -d= -f2-)
    echo -e "  ${CYAN}Cloud:${NC}      ${cloud_url:-not set}"
    echo -e "  ${CYAN}Platforms:${NC}  ${platforms:-web}"
    echo -e "  ${CYAN}Node Name:${NC}  ${node_name:-$(hostname)}"
  else
    echo -e "  ${CYAN}Config:${NC}     ${RED}.env not found${NC}"
  fi

  # Auto-updater status
  if launchctl list "$LAUNCHD_UPDATER_LABEL" &>/dev/null; then
    echo -e "  ${CYAN}Auto-update:${NC} ${GREEN}Enabled${NC} (hourly)"
  else
    echo -e "  ${CYAN}Auto-update:${NC} ${YELLOW}Disabled${NC}"
  fi

  # Check for pending updates
  cd "$KRC_HOME"
  git fetch origin main --quiet 2>/dev/null || true
  local LOCAL=$(git rev-parse HEAD 2>/dev/null)
  local REMOTE=$(git rev-parse origin/main 2>/dev/null)
  if [ -n "$LOCAL" ] && [ -n "$REMOTE" ] && [ "$LOCAL" != "$REMOTE" ]; then
    local behind=$(git rev-list --count HEAD..origin/main 2>/dev/null || echo "?")
    echo -e "  ${CYAN}Updates:${NC}    ${YELLOW}${behind} commit(s) behind — run 'krc update'${NC}"
  fi

  echo ""
}

cmd_logs() {
  local lines="${1:-50}"
  if [ -f "$KRC_LOG_FILE" ]; then
    tail -n "$lines" -f "$KRC_LOG_FILE"
  else
    echo -e "${YELLOW}No log file found at $KRC_LOG_FILE${NC}"
  fi
}

cmd_config() {
  local editor="${EDITOR:-nano}"
  if [ ! -f "$KRC_HOME/.env" ]; then
    cp "$KRC_HOME/.env.example" "$KRC_HOME/.env" 2>/dev/null || touch "$KRC_HOME/.env"
  fi
  "$editor" "$KRC_HOME/.env"
  echo -e "${YELLOW}Restart KRC to apply changes: krc restart${NC}"
}

cmd_enable_autoupdate() {
  if [ -f "$KRC_HOME/launchd/$LAUNCHD_UPDATER_LABEL.plist" ]; then
    cp "$KRC_HOME/launchd/$LAUNCHD_UPDATER_LABEL.plist" "$PLIST_DIR/"
    # Replace placeholder
    sed -i '' "s|__KRC_HOME__|$KRC_HOME|g" "$PLIST_DIR/$LAUNCHD_UPDATER_LABEL.plist"
    sed -i '' "s|__USER__|$(whoami)|g" "$PLIST_DIR/$LAUNCHD_UPDATER_LABEL.plist"
    launchctl load "$PLIST_DIR/$LAUNCHD_UPDATER_LABEL.plist"
    echo -e "${GREEN}Auto-update enabled (hourly check)${NC}"
  else
    echo -e "${RED}Updater plist not found${NC}"
  fi
}

cmd_disable_autoupdate() {
  if [ -f "$PLIST_DIR/$LAUNCHD_UPDATER_LABEL.plist" ]; then
    launchctl unload "$PLIST_DIR/$LAUNCHD_UPDATER_LABEL.plist" 2>/dev/null || true
    rm -f "$PLIST_DIR/$LAUNCHD_UPDATER_LABEL.plist"
    echo -e "${GREEN}Auto-update disabled${NC}"
  else
    echo -e "${YELLOW}Auto-update is already disabled${NC}"
  fi
}

cmd_setup() {
  bash "$KRC_HOME/bin/krc-setup.sh"
}

cmd_doctor() {
  print_banner
  echo -e "${CYAN}Running diagnostics...${NC}"
  echo ""

  # Check for orphan processes
  local node_pids=$(pgrep -f "node.*dist/main.js" 2>/dev/null || true)
  local tsnode_pids=$(pgrep -f "ts-node-dev.*src/main.ts" 2>/dev/null || true)
  local all_pids="$node_pids"$'\n'"$tsnode_pids"
  all_pids=$(echo "$all_pids" | sed '/^$/d')
  local count=$(echo "$all_pids" | sed '/^$/d' | wc -l | xargs)

  if [ "$count" -gt 1 ]; then
    echo -e "  ${RED}✗ Multiple KRC processes detected ($count)${NC}"
    echo -e "    This causes tunnel disconnect loops. Run: ${CYAN}krc restart${NC}"
    echo "$all_pids" | while read pid; do
      [ -z "$pid" ] && continue
      local cmd=$(ps -p "$pid" -o command= 2>/dev/null | head -c 80)
      echo -e "    PID $pid: $cmd"
    done
  elif [ "$count" -eq 1 ]; then
    echo -e "  ${GREEN}✓${NC} Single KRC process (PID: $(echo "$all_pids" | head -1))"
  else
    echo -e "  ${YELLOW}–${NC} KRC not running"
  fi

  # Check port binding
  if lsof -i :5001 -sTCP:LISTEN &>/dev/null; then
    echo -e "  ${GREEN}✓${NC} Port 5001 bound"
  else
    echo -e "  ${YELLOW}–${NC} Port 5001 not bound (KRC may not be running)"
  fi

  # Check tunnel connectivity
  local cloud_url=$(grep CLOUD_API_URL "$KRC_HOME/.env" 2>/dev/null | cut -d= -f2-)
  if [ -n "$cloud_url" ]; then
    if curl -s --connect-timeout 3 "$cloud_url/../health" &>/dev/null || curl -s --connect-timeout 3 "$cloud_url" &>/dev/null; then
      echo -e "  ${GREEN}✓${NC} KCD reachable ($cloud_url)"
    else
      echo -e "  ${RED}✗ KCD unreachable ($cloud_url)${NC}"
    fi
  fi

  # Check platforms and dependencies
  local platforms=$(grep RUNNER_PLATFORMS "$KRC_HOME/.env" 2>/dev/null | cut -d= -f2-)
  echo -e "  ${CYAN}Platforms:${NC} ${platforms:-web}"

  if echo "$platforms" | grep -q "android"; then
    if command -v adb &>/dev/null; then
      local adb_count=$(adb devices 2>/dev/null | grep -c 'device$' || echo 0)
      echo -e "  ${GREEN}✓${NC} adb installed (${adb_count} device(s))"
    else
      echo -e "  ${RED}✗ adb not found${NC} — brew install --cask android-platform-tools"
    fi
    if command -v java &>/dev/null; then
      echo -e "  ${GREEN}✓${NC} Java $(java -version 2>&1 | head -1 | grep -oE '"[^"]+"' || echo 'found')"
    else
      echo -e "  ${RED}✗ Java not found${NC} — brew install openjdk@17"
    fi
    if [ -n "${ANDROID_HOME:-}" ] || [ -d "$HOME/Library/Android/sdk" ]; then
      echo -e "  ${GREEN}✓${NC} ANDROID_HOME set"
    else
      echo -e "  ${YELLOW}⚠ ANDROID_HOME not set${NC}"
    fi
    if command -v appium &>/dev/null; then
      local has_uia2=$(appium driver list 2>/dev/null | grep -c "uiautomator2.*installed" || echo 0)
      echo -e "  ${GREEN}✓${NC} Appium $(appium --version 2>/dev/null || echo 'installed') (UiAutomator2: ${has_uia2})"
    else
      echo -e "  ${RED}✗ Appium not found${NC} — npm install -g appium"
    fi
  fi

  if echo "$platforms" | grep -q "ios"; then
    if command -v xcrun &>/dev/null; then
      echo -e "  ${GREEN}✓${NC} Xcode CLI tools"
    else
      echo -e "  ${RED}✗ Xcode CLI tools not found${NC} — xcode-select --install"
    fi
  fi

  # Check launchd plist
  if [ -f "$PLIST_DIR/$LAUNCHD_LABEL.plist" ]; then
    if grep -q "__JAVA_HOME__\|__ANDROID_HOME__\|__KRC_HOME__\|__USER__" "$PLIST_DIR/$LAUNCHD_LABEL.plist"; then
      echo -e "  ${RED}✗ launchd plist has unresolved placeholders${NC}"
      echo -e "    Re-run: ${CYAN}install.sh${NC} or update plist manually"
    else
      echo -e "  ${GREEN}✓${NC} launchd plist OK"
    fi
  else
    echo -e "  ${YELLOW}–${NC} No launchd plist (direct-start mode)"
  fi

  echo ""
}

cmd_help() {
  print_banner
  echo "Usage: krc <command>"
  echo ""
  echo "Commands:"
  echo "  setup              Interactive setup (create runner, configure .env)"
  echo "  start              Start KRC"
  echo "  stop               Stop KRC"
  echo "  restart            Restart KRC"
  echo "  status             Show KRC status"
  echo "  doctor             Diagnose issues (orphan processes, deps, tunnel)"
  echo "  update             Check and apply updates"
  echo "  logs [lines]       Tail KRC logs (default: 50, follow mode)"
  echo "  config             Edit .env configuration"
  echo "  enable-autoupdate  Enable hourly auto-update check"
  echo "  disable-autoupdate Disable auto-update"
  echo "  version            Show current version"
  echo "  help               Show this help"
  echo ""
}

# Main dispatch
case "${1:-help}" in
  setup)              cmd_setup ;;
  start)              cmd_start ;;
  stop)               cmd_stop ;;
  restart)            cmd_restart ;;
  update)             cmd_update ;;
  status)             cmd_status ;;
  doctor)             cmd_doctor ;;
  logs)               cmd_logs "${2:-50}" ;;
  config)             cmd_config ;;
  enable-autoupdate)  cmd_enable_autoupdate ;;
  disable-autoupdate) cmd_disable_autoupdate ;;
  version)            echo "KRC $(get_version)" ;;
  help|--help|-h)     cmd_help ;;
  *)
    echo -e "${RED}Unknown command: $1${NC}"
    cmd_help
    exit 1
    ;;
esac
